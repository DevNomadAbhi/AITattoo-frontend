{
  "expo": {
    "name": "TattooApp",
    "slug": "TattooApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tattooapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow TattooApp to access your camera so you can preview tattoo placement live."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/tattoo_hunter_crop.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#0d0907",
          "dark": {
            "backgroundColor": "#0d0907"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow the app to access your photos to try on tattoos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow TattooApp to access your photo library when saving tattoo previews.",
          "savePhotosPermission": "Allow TattooApp to save captured tattoo previews to your photo library.",
          "granularPermissions": ["photo"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
